{
  "name": "lotro-fansite",
  "version": "1.0.0",
  "description": "Lord of the Rings Online fansite - Markdown-powered static site generator",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node serve.js",
    "dev": "node build.js --local && node serve.js",
    "prebuild": "node scripts/download-cdn-data.js",
    "build": "node build.js",
    "heroku-postbuild": "node scripts/scrape-news.js || true && node build.js",
    "watch": "node build.js --watch",
    "scrape": "node scripts/scrape-news.js",
    "scrape:build": "node scripts/scrape-news.js && node build.js",
    "import:loot": "node scripts/import-lotro-companion-loot.js",
    "enrich:skills": "node scripts/enrich-instance-skills.js",
    "extract:lore": "node scripts/extract-lore.js",
    "extract:icons": "node scripts/extract-icons.js",
    "extract:all": "node scripts/extract-lore.js && node scripts/extract-icons.js",
    "sync:cdn": "node scripts/sync-cdn.js",
    "fetch:videos": "node scripts/fetch-youtube-videos.js"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "prosemirror-commands": "^1.6.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-markdown": "^1.13.1",
    "prosemirror-model": "^1.24.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.37.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "adm-zip": "^0.5.17",
    "xlsx": "^0.18.5"
  }
}
