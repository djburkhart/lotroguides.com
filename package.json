{
  "name": "lotroguides.com",
  "version": "2.5.3",
  "description": "Lord of the Rings Online fansite - Markdown-powered static site generator",
  "author": {
    "name": "Daniel Burkhart",
    "email": "me@danielburkhart.com"
  },
  "homepage": "https://lotroguides.com",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "test": "node scripts/vendor-giseldah-calcstat.js && node --test --test-isolation=none test/discord-statcaps.test.js test/vendor-giseldah-calcstat.test.js",
    "start": "node serve.js",
    "dev": "node scripts/vendor-giseldah-calcstat.js && node build.js --local && node serve.js",
    "prebuild": "node scripts/vendor-giseldah-calcstat.js && node scripts/download-cdn-data.js",
    "build": "node build.js",
    "heroku-postbuild": "node scripts/scrape-news.js || true && node scripts/vendor-giseldah-calcstat.js && node build.js",
    "watch": "node scripts/vendor-giseldah-calcstat.js && node build.js --watch",
    "update:news": "node scripts/scrape-news.js",
    "update:loot": "node scripts/import-lotro-companion-loot.js && node scripts/import-loot.js",
    "update:skills": "node scripts/enrich-instance-skills.js",
    "update:lore": "node scripts/extract-lore.js",
    "update:icons": "node scripts/extract-icons.js",
    "update:videos": "node scripts/fetch-youtube-videos.js && node scripts/fetch-instance-videos.js",
    "update:maps": "node scripts/sync-maps.js",
    "update": "npm run update:news && npm run update:loot && npm run update:skills && npm run update:maps && npm run update:lore && npm run update:icons && npm run update:videos",
    "sync": "node scripts/sync-cdn.js",
    "deploy:functions": "node scripts/vendor-giseldah-calcstat.js && node scripts/deploy-functions.js",
    "deploy:discord": "node scripts/vendor-giseldah-calcstat.js && node scripts/deploy-functions.js discord && node scripts/register-discord-commands.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "chokidar": "^3.6.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "fastify": "^5.8.4",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "prosemirror-commands": "^1.6.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-markdown": "^1.13.1",
    "prosemirror-model": "^1.24.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.37.1",
    "sharp": "^0.34.5",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "adm-zip": "^0.5.17"
  }
}
