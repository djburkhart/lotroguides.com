# Google Analytics measurement ID
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Google Tag Manager container ID
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXXX

# Google AdSense publisher account
GOOGLE_ADSENSE_ACCOUNT=ca-pub-XXXXXXXXXXXXXXXX

# Google OAuth credentials for admin login
GOOGLE_OAUTH_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Admin email for site editing access (comma-separated for multiple)
EDITOR_ALLOWED_EMAILS=my@editoremail.com

# GitHub repo for editor integration (owner/repo format)
GITHUB_REPO=djburkhart/lotroguides.com

# GitHub OAuth App credentials for editor commits
# Only GITHUB_CLIENT_ID is needed at build time (injected into editor config).
# GITHUB_CLIENT_SECRET is configured in the DO Function environment only.
GITHUB_CLIENT_ID=Iv1.XXXXXXXXXXXXXXXXXXXX

# Google Search Console HTML tag verification code
# Get this from Search Console → Settings → Ownership verification → HTML tag
# Copy only the content="..." value, e.g. "abc123XYZverify..."
GOOGLE_SEARCH_CONSOLE_VERIFICATION=

# Cusdis comments widget
# Get your App ID from https://cusdis.com/dashboard — create a site, copy the data-app-id
CUSDIS_APP_ID=
CUSDIS_HOST=https://cusdis.com

# Google reCAPTCHA Enterprise site key (optional, protects comment form)
RECAPTCHA_SITE_KEY=

# CDN URL for static assets (set in DO App Platform as BUILD_TIME secret)
DO_CDN_URL=https://cdn.lotroguides.com

# DigitalOcean Spaces credentials (for npm run sync:cdn — NOT needed at build time)
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_REGION=nyc3

# CDN Upload serverless function URL (for editor CDN save)
CDN_UPLOAD_URL=https://your-functions-url/api/cdn/upload

# YouTube Data API v3 key (for fetching official channel videos)
# Get one at https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" for your project
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CHANNEL_HANDLE=@lordoftherings

# Discord Bot (for slash-command interactions endpoint)
# Get these from https://discord.com/developers/applications
DISCORD_APP_ID=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=