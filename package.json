{
  "name": "lotro-fansite",
  "version": "1.0.0",
  "description": "Lord of the Rings Online fansite - Markdown-powered static site generator",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node serve.js",
    "build": "node build.js",
    "heroku-postbuild": "node scrape-news.js || true && node build.js",
    "watch": "node build.js --watch",
    "scrape": "node scrape-news.js",
    "scrape:build": "node scrape-news.js && node build.js",
    "import:loot": "node import-lotro-companion-loot.js"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "sharp": "^0.34.5"
  }
}
